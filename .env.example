# NapCatQQ 正向 WebSocket 地址
NAPCAT_WS_URL=ws://127.0.0.1:3001
# 如果 NapCat 配置了 access_token，填在这里；没有就留空
NAPCAT_ACCESS_TOKEN=

# OpenAI 兼容 API 配置（代码走的是 OpenAI SDK，只要接口兼容 OpenAI 协议即可，
# 例如 DeepSeek：BASE_URL 填 https://api.deepseek.com，KEY 填你的 DeepSeek API Key）
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# 主人的 QQ 号，用于隐藏后门指令（!rename / !q）鉴权，以及每日主动搭话调度
MASTER_QQ=123456789
